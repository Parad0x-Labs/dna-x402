{
  "name": "pdx-dark-protocol-extension",
  "version": "1.0.0",
  "description": "Browser extension for PDX Dark Protocol - Privacy-preserving transfers on Solana",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "package": "web-ext build --source-dir . --artifacts-dir ./dist"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.87.6",
    "@solana/spl-token": "^0.3.9",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "web-ext": "^7.8.0"
  },
  "webExt": {
    "sourceDir": ".",
    "build": {
      "overwriteDest": true
    }
  }
}
