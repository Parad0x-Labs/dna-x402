{
  "name": "@parad0x_labs/receipt-dag",
  "version": "0.3.0",
  "description": "Cross-layer anti-equivocation DAG for x402 agent receipts. Append-only, tamper-evident history across stack layers (payment, x402-access, shielded, reputation, job); two receipts from the same agent with the same sequenceNonce is cryptographic proof of cheating.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "node --test tests/merkle.test.mjs tests/cross-layer.test.mjs"
  },
  "keywords": [
    "solana",
    "x402",
    "dag",
    "receipts",
    "anti-equivocation",
    "merkle",
    "agents",
    "dna-x402",
    "append-only",
    "tamper-evident"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Parad0x-Labs/dna-x402"
  },
  "homepage": "https://github.com/Parad0x-Labs/dna-x402/tree/main/packages/receipt-dag",
