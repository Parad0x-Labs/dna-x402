{
  "name": "@parad0x_labs/context-capsule",
  "version": "0.1.0",
  "description": "LLM token compression layer for nulla-local and OpenClaw agents. Compress session history before injection — stop paying for full history on every call.",
  "main": "src/index.ts",
  "types": "src/index.ts",
