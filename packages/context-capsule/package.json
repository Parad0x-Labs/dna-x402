  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src/",
    "tests/"
  ],
  "scripts": {
    "test": "node --test tests/context-capsule.test.mjs",
    "bench:public": "node --experimental-strip-types scripts/bench-public.ts",
    "test:quality": "node --test tests/context-capsule-quality.test.mjs"
  },
  "keywords": [
    "llm", "context-compression", "ai-agents", "token-savings",
    "merkle", "zlib", "capsule", "nulla-local", "openclaw",
    "dna-x402", "parad0x-labs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Parad0x-Labs/dna-x402"
  },
