{
  "name": "task-marketplace-api",
  "version": "0.1.0",
  "type": "module",
  "description": "NULL Miner task marketplace — serves real tasks to SDK agents via REST",
  "private": true,
  "scripts": {
    "dev":   "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "test":  "node ../../node_modules/jest/bin/jest.js --forceExit"
  },
  "dependencies": {
    "cors":    "^2.8.5",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors":       "^2.8.17",
    "@types/express":    "^5.0.0",
    "@types/jest":       "^30.0.0",
    "@types/node":       "^22.0.0",
    "@types/supertest":  "^6.0.0",
    "jest":              "^29.0.0",
    "supertest":         "^7.0.0",
    "ts-jest":           "^29.0.0",
    "tsx":               "^4.19.0",
    "typescript":        "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "useESM": false }]
    }
  }
}
