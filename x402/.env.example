# DNA x402 Server Configuration
# Copy to .env and fill in your values

# Solana cluster (devnet, testnet, mainnet-beta)
CLUSTER=mainnet-beta

# Solana RPC endpoint (Helius, QuickNode, or public)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Preferred for mainnet drills: set either HELIUS_RPC as the full endpoint
# or HELIUS_API_KEY and let the drill build https://mainnet.helius-rpc.com/?api-key=...
HELIUS_RPC=
HELIUS_API_KEY=
HELIUS_RPC_BASE_URL=https://mainnet.helius-rpc.com/

# USDC mint address (mainnet)
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Your Solana wallet that receives payments
PAYMENT_RECIPIENT=YOUR_WALLET_ADDRESS

# Ed25519 secret key for signing receipts (base58 encoded)
RECEIPT_SIGNING_SECRET=YOUR_BASE58_ED25519_SECRET

# Receipt anchor program ID (deployed on Solana)
RECEIPT_ANCHOR_PROGRAM_ID=6HSRGivdYR5D7yTDy1TFMCM8h3LzXxRtKU1RA3RnCMRN

# Enable on-chain receipt anchoring (1=yes, 0=no)
ANCHORING_ENABLED=1
ANCHORING_KEYPAIR_PATH=./test-mainnet/keys/mainnet/anchoring.json
ANCHORING_SIGNATURE_LOG_PATH=./test-mainnet/keys/mainnet/anchor-signatures.log

# Fee in basis points (30 = 0.3%)
FEE_BPS=30

# Server port
PORT=8080

# Database / local durable snapshot
X402_DB_DRIVER=postgres
X402_REPOSITORY_MODE=postgres
X402_DATABASE_URL=postgres://x402:x402_local@localhost:5432/x402_local
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/dna_x402
X402_DB_SNAPSHOT=./.runtime/db/commerce-state.json
X402_DB_BACKUP_DIR=./.runtime/backups

# Policy and product gates
POLICY_VERSION=policy-v1
NODE_ENV=production
PUBLIC_MARKETPLACE_ENABLED=0
LIVE_MONEY_MOVEMENT_ENABLED=0
POLYMARKET_LIVE_MOVEMENT_ENABLED=0
PUBLIC_NETTING_ENABLED=0
PUBLIC_PHYSICAL_GOODS_ENABLED=0
PUBLIC_HIGH_RISK_CATEGORIES_ENABLED=0
X402_ENABLE_PUBLIC_MARKETPLACE=0
X402_ENABLE_PROD_MONEY=0
X402_ENABLE_POLYMARKET_LIVE=0
X402_ENABLE_PUBLIC_NETTING=0
X402_ENABLE_PHYSICAL_GOODS=0
X402_ENABLE_HIGH_RISK_CATEGORIES=0
X402_ENABLE_MULTI_CHAIN_SETTLEMENT=0
X402_ENABLE_UNATTENDED_SIGNING=0
X402_ENABLE_BACKEND_KEY_CUSTODY=0
X402_ENABLE_WEBHOOK_DELIVERY=0
X402_ENABLE_FINALIZE=1
X402_ENABLE_QUOTES=1
X402_ENABLE_WEBHOOK_RECEIVER_TEST=0
X402_ENABLE_REAL_CHAIN_DRILL=0
X402_REAL_CHAIN_ALLOWED_SIGNERS=
X402_REAL_CHAIN_MAX_TX_ATOMIC=100000
X402_REAL_CHAIN_DAILY_CAP_ATOMIC=5000000
X402_REAL_CHAIN_FEE_MODE=none
X402_REAL_CHAIN_PLATFORM_FEE_BPS=0
X402_REAL_CHAIN_PLATFORM_RECIPIENT=

# Builder / integrator monetization
# Defaults are safe for local demos: visible/accrual architecture only, no direct collection.
# Public Beta live paid flows must use DNA 10 bps direct split:
# X402_PLATFORM_FEE_MODE=direct_split
# X402_PLATFORM_FEE_TREASURY=<dna-treasury-public-wallet>
# X402_ENABLE_DIRECT_SPLIT_FEES=1
# X402_DIRECT_SPLIT_GATE_REF=<approved-public-beta-direct-split-gate>
# FEE_BPS=0, BASE_FEE_ATOMIC=0, MIN_FEE_ATOMIC=0
# Helius RPC, Telegram alerts, client-side signing, and beta caps.
X402_PLATFORM_FEE_BPS=10
X402_PLATFORM_FEE_MODE=display_only
X402_PLATFORM_FEE_TREASURY=
X402_ENABLE_BUILDER_FEES=true
X402_BUILDER_FEE_DEFAULT_MODE=display_only
X402_BUILDER_FEE_MAX_BPS=500
X402_ENABLE_AFFILIATE_FEES=false
X402_AFFILIATE_FEE_MAX_BPS=200
X402_ENABLE_DIRECT_SPLIT_FEES=false
X402_DIRECT_SPLIT_GATE_REF=
X402_ENABLE_AUTO_SWEEP=false
X402_AUTO_SWEEP_THRESHOLD_SOL=

X402_PROD_MONEY_CHECKLIST_REF=
X402_POLYMARKET_LIVE_CHECKLIST_REF=
X402_PUBLIC_NETTING_CHECKLIST_REF=
X402_PHYSICAL_GOODS_CHECKLIST_REF=
X402_HIGH_RISK_CATEGORIES_CHECKLIST_REF=
X402_MULTI_CHAIN_SETTLEMENT_CHECKLIST_REF=
X402_PUBLIC_MARKETPLACE_CHECKLIST_REF=
X402_WEBHOOK_DELIVERY_CHECKLIST_REF=

# WARNING: netting is unsigned off-chain credit, not a trustless payment proof.
# Leave this at 0 unless you are running a trusted bilateral settlement setup.
UNSAFE_UNVERIFIED_NETTING_ENABLED=0

# Admin API secret (for /admin/* endpoints)
ADMIN_SECRET=your-admin-secret

# Webhook signing secret (HMAC-SHA256)
WEBHOOK_SIGNING_SECRET=your-webhook-secret

# External Telegram ops alerts (token must come from local env/server secret)
X402_ALERT_TELEGRAM_ENABLED=false
X402_ALERT_TELEGRAM_BOT_TOKEN=
X402_ALERT_TELEGRAM_CHAT_ID=
X402_ALERT_TELEGRAM_PARSE_MODE=HTML
X402_ALERT_TELEGRAM_RELAY_SECRET=
X402_ALERT_TELEGRAM_COMMANDS_ENABLED=false
X402_ALERT_TELEGRAM_ALLOWED_USER_IDS=
X402_ALERT_TELEGRAM_ALLOWED_ADMIN_IDS=
X402_ALERT_TELEGRAM_ALLOWED_CHAT_IDS=
X402_ALERT_TELEGRAM_STATUS_METRICS_URL=http://127.0.0.1:8080/metrics

# Audit log file path
AUDIT_LOG_PATH=./audit.ndjson

# DNA Guard (optional server-side risk layer)
DNA_GUARD_ENABLED=0
DNA_GUARD_FAIL_MODE=fail-open
DNA_GUARD_WINDOW_MS=86400000
DNA_GUARD_SNAPSHOT_PATH=./state/dna-guard.json
DNA_GUARD_BUYER_CEILING_ATOMIC=
DNA_GUARD_WALLET_CEILING_ATOMIC=
DNA_GUARD_AGENT_CEILING_ATOMIC=
DNA_GUARD_API_KEY_CEILING_ATOMIC=

# Allow insecure mode (development only, set to 0 for production)
ALLOW_INSECURE=0
