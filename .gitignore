# Deploy keypairs - NEVER commit private keys
# These files define program IDs; leaking them enables race attacks on those addresses.
scripts/keypairs/**/*.json
!scripts/keypairs/.gitkeep
**/*keypair*.json
**/id.json

# Solana build artifacts
target/deploy/*.so
target/deploy/*.json

# Solana program builds (large binaries)
programs/*/target/

# Cargo package cache — never commit registry cache
.cargo-home/

# Site exports / tarballs / packed npm artifacts
exports/
*.tgz

# Workspace package-level lockfiles — root package-lock.json is the authority
packages/*/package-lock.json

# Test compilation artifacts (ts-jest/IDE stray output)
packages/*/tests/*.d.ts
packages/*/tests/*.d.ts.map
packages/*/tests/*.js.map

