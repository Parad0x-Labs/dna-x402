{
  "name": "dark-null-protocol-workspace",
  "private": true,
  "version": "0.1.0",
  "devDependencies": {
    "@solana/web3.js": "^1.98.4",
    "tsx": "^4.19.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "null-miner:build":     "npm --prefix packages/null-miner-sdk run build",
    "null-miner:test":      "npm --prefix packages/null-miner-sdk run test",
    "marketplace:start":    "npm --prefix packages/task-marketplace-api run start",
    "marketplace:dev":      "npm --prefix packages/task-marketplace-api run dev",
    "extension:build":      "npm --prefix examples/null-miner-extension run build",
    "extension:dev":        "npm --prefix examples/null-miner-extension run dev",
    "site:build": "npm --prefix site run build",
    "site-agent:dev": "npm --prefix site-agent run dev",
    "site-agent:build": "npm --prefix site-agent run build",
    "site-agent:preview": "npm --prefix site-agent run preview -- --host --port 4174",
    "site-agent:test": "npm --prefix site-agent run test",
    "site-agent:proof:sync": "npm --prefix site-agent run proof:sync",
    "mayhem:x402": "npm --prefix x402 run mayhem:x402",
    "mayhem:x402:sandbox": "npm --prefix x402 run mayhem:x402:sandbox",
    "mayhem:x402:server": "npm --prefix x402 run mayhem:x402:server",
    "db:migrate": "npm --prefix x402 run db:migrate",
    "db:health": "npm --prefix x402 run db:health",
    "db:backup:test:postgres": "npm --prefix x402 run db:backup:test:postgres",
    "check:style": "node scripts/check-style-terms.mjs",
    "acceptance:builder": "npm --prefix x402 run acceptance:builder",
    "acceptance:agents": "npm --prefix x402 run acceptance:agents",
    "acceptance:degen-mode": "npm --prefix x402 run acceptance:degen-mode"
  }
}
